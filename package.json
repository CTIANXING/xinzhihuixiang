{
  "name": "sillytavern-web-vanilla",
  "version": "1.0.0",
  "private": true,
  "description": "SillyTavern Web Integration (Vanilla JS)",
  "scripts": {
    "build": "npm run bundle",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "bundle": "esbuild src/game-entry.ts --bundle --format=esm --outfile=dist/game-bundle.js --target=es2020",
    "bundle:watch": "esbuild src/game-entry.ts --bundle --format=esm --outfile=dist/game-bundle.js --target=es2020 --watch"
  },
  "dependencies": {
    "dexie": "^4.0.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  }
}
